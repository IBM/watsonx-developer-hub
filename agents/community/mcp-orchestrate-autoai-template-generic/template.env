# Copy to .env and fill in real values.
# DO NOT commit the .env file.

WATSONX_URL=https://us-south.ml.cloud.ibm.com
WATSONX_API_KEY=
WATSONX_SPACE_ID=
WATSONX_AUTOAI_DEPLOYMENT_ID=

# Optional: LLM to use in the generated agent.yaml.
# Defaults to "groq/openai/gpt-oss-120b" if not set.
# Override this if that model is not available on your Orchestrate instance.
# LLM_NAME=groq/openai/gpt-oss-120b
