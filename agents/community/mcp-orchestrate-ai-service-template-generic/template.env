WATSONX_URL=https://us-south.ml.cloud.ibm.com
WATSONX_API_KEY=your_api_key
WATSONX_SPACE_ID=your_space_id

# Single deployment ID (legacy support)
# WATSONX_AI_SERVICE_DEPLOYMENT_ID=your_autoai_rag_pattern_deployment_id

# Multiple deployment IDs (recommended)
# Add as many as needed, incrementing the number
WATSONX_AI_SERVICE_DEPLOYMENT_ID_1=your_first_deployment_id
WATSONX_AI_SERVICE_DEPLOYMENT_ID_2=your_second_deployment_id
# WATSONX_AI_SERVICE_DEPLOYMENT_ID_3=your_third_deployment_id